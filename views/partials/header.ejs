<!DOCTYPE html>
<html lang="<%= lang === 'en' ? 'en' : 'zh-CN' %>" data-theme="<%= theme || 'light' %>">
<head>
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#8b5a2b" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Bible Read" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="mobile-web-app-capable" content="yes" />
  <title><%= title %> | <%= t('appName') %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="mobile-app <%= currentUser ? 'has-bottom-nav' : 'guest-layout' %> theme-<%= theme || 'light' %>">
  <% if (pageTitle) { %>
    <header class="page-header">
      <h1 class="page-header-title"><%= pageTitle %></h1>
    </header>
  <% } %>
  <main class="container">
