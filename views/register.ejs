<%- include('partials/header') %>

<div class="card" style="max-width:480px; margin:2rem auto;">
  <% if (errors && errors.length) { %>
    <ul class="error-list">
      <% errors.forEach(function(e) { %>
        <li><%= e.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form action="/register" method="POST">
    <div class="form-group">
      <label for="username"><%= t('auth.username') %></label>
      <input type="text" id="username" name="username" required
        value="<%= old.username || '' %>" minlength="2" maxlength="30" />
    </div>
    <div class="form-group">
      <label for="email"><%= t('auth.email') %></label>
      <input type="email" id="email" name="email" required
        value="<%= old.email || '' %>" />
    </div>
    <div class="form-group">
      <label for="password"><%= t('auth.passwordHint') %></label>
      <input type="password" id="password" name="password" required minlength="6" />
    </div>
    <div class="form-group">
      <label for="group"><%= t('auth.chooseGroup') %></label>
      <select id="group" name="group" required>
        <option value=""><%= t('auth.choosePlaceholder') %></option>
        <% groups.forEach(function(g) { %>
          <option value="<%= g.name %>"
            <%= old.group === g.name ? 'selected' : '' %>>
            <%= t('auth.groupOption', { goal: g.weeklyGoal, leader: g.leader }) %>
          </option>
        <% }) %>
      </select>
    </div>
    <button type="submit" class="btn btn-primary"><%= t('auth.submitRegister') %></button>
  </form>
  <p style="margin-top:1rem;"><%= t('auth.hasAccount') %> <a href="/login"><%= t('auth.goLogin') %></a></p>
</div>

<%- include('partials/footer') %>
